# ─── DISCORD BOT ────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ─── DATABASE ───────────────────────────────────────
DATABASE_URL=sqlite:///data/bot.db

# ─── LEGACY TEMPORARY VOICE ROOMS (Optional fallback) ─
CREATE_ROOM_CHANNEL_ID=
TEMP_ROOM_CATEGORY_ID=

# ════════════════════════════════════════════════════

# DISCORD BOT — AI CONFIG

# ════════════════════════════════════════════════════

AI_PROVIDER_ORDER=groq,gemini,openrouter,huggingface

GROQ_API_KEY=your_groq_key
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant

GEMINI_API_KEY=your_gemini_key
GOOGLE_API_KEY=your_gemini_key
GEMINI_FLASH_MODEL=gemini-3.5-flash
GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite

OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_SITE_URL=https://localhost
OPENROUTER_APP_NAME=Study Discord Bot

HUGGINGFACE_API_KEY=your_huggingface_key
HUGGING_FACE_API_KEY=your_huggingface_key
HF_TOKEN=your_huggingface_key
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

AI_HTTP_TIMEOUT=60
AI_ONE_MESSAGE_LIMIT=1900
AI_MAX_OUTPUT_TOKENS=1600
AI_TEMPERATURE=0.5

AI_SYSTEM_PROMPT=You are a smart, direct general-purpose AI assistant inside a Discord server. Reply in the same language as the user. Answer any normal topic honestly and helpfully. For simple questions, answer in 1-3 sentences. For moderate questions, answer with enough detail using short paragraphs or bullets. For complex questions, explain clearly with structure, examples, formulas, or code blocks when useful. Never pad answers. Never be shallow. Keep the answer inside one Discord message. Use Discord markdown when helpful. If unsure, say so briefly.

# ─── TIMEZONE / DASHBOARD ───────────────────────────
TZ=Asia/Ho_Chi_Minh
DASHBOARD_PORT=5000
DATA_DIR=/data

# ─── ECONOMY / LOANS (Optional defaults) ────────────
COINS_PER_MINUTE=10
BOT_LOAN_INTEREST_PERCENT=10
BOT_LOAN_DAYS=7
MAX_BOT_LOAN_AMOUNT=5000
MAX_ACTIVE_LOANS=3
MAX_PENDING_LOAN_OFFERS=10
TRANSACTION_HISTORY_LIMIT=100
LOAN_HISTORY_LIMIT=50

# ─── RUNTIME SAFETY ─────────────────────────────────
RUNTIME_RESTORE_MAX_AGE_SECONDS=1800
