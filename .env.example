# ─── DISCORD BOT ────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ─── OPENROUTER API (Optional) ──────────────────────
OPENROUTER_API_KEY=

# ─── TIMEZONE ───────────────────────────────────────
TZ=Asia/Ho_Chi_Minh

# ─── DASHBOARD PORT (Optional - default 5000) ───────
DASHBOARD_PORT=5000

# ─── DATA DIRECTORY (Auto-managed by Docker) ────────
DATA_DIR=/data