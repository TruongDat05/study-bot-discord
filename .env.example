# ─── DISCORD BOT ────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ─── TEMPORARY VOICE ROOMS (Optional) ───────────────
CREATE_ROOM_CHANNEL_ID=
TEMP_ROOM_CATEGORY_ID=

# ─── AI PROVIDERS (Optional; fallback order in bot.py) ─
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
GROQ_MODELS=llama-3.3-70b-versatile,qwen/qwen3-32b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Study Discord Bot
HUGGINGFACE_API_KEY=
HUGGING_FACE_API_KEY=
HF_TOKEN=
HUGGINGFACE_MODEL=deepseek-ai/DeepSeek-R1:fastest
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash-lite
AI_HTTP_TIMEOUT=45
AI_ONE_MESSAGE_LIMIT=1750
AI_MAX_OUTPUT_TOKENS=900

# ─── TIMEZONE / DASHBOARD ───────────────────────────
TZ=Asia/Ho_Chi_Minh
DASHBOARD_PORT=5000
DATA_DIR=/data

# ─── ECONOMY / LOANS (Optional defaults) ────────────
COINS_PER_MINUTE=10
BOT_LOAN_INTEREST_PERCENT=10
BOT_LOAN_DAYS=7
MAX_BOT_LOAN_AMOUNT=5000
MAX_ACTIVE_LOANS=3
MAX_PENDING_LOAN_OFFERS=10
TRANSACTION_HISTORY_LIMIT=100
LOAN_HISTORY_LIMIT=50

# ─── RUNTIME SAFETY ─────────────────────────────────
RUNTIME_RESTORE_MAX_AGE_SECONDS=1800
